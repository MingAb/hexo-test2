<main class="flex-1 w-full flex justify-center px-6 md:px-20 pt-24 md:pt-28 pb-16">
  <section class="w-full max-w-5xl mx-auto">
    <header class="mb-10">
      <div class="flex items-center space-x-3 mb-3">
        <span class="h-px w-8 md:w-12 bg-secondary"></span>
        <span class="font-label text-[10px] md:text-xs uppercase tracking-[0.3em] text-secondary dark:text-orange-400 font-bold">
          作品集合
        </span>
      </div>
      <h1 class="font-headline text-4xl md:text-5xl text-primary dark:text-white leading-tight tracking-tight mb-3">
        实验与作品库
      </h1>
      <p class="font-body text-sm md:text-base text-on-surface-variant dark:text-gray-300 max-w-2xl">
        这里收录的是一些完整度较高的项目：从零碎想法到可以在线访问的 Demo。点进每个作品，可以看到它从草稿到落地的全过程记录。
      </p>
    </header>

    <% var postsArray = site.posts && site.posts.toArray ? site.posts.toArray() : (site.posts || []); %>
    <% var projects = postsArray.filter(function (p) { return p.layout === 'project'; }); %>

    <% if (!projects.length) { %>
      <p class="text-on-surface-variant dark:text-gray-400 text-sm">
        还没有任何作品条目。你可以创建带有 <code>layout: project</code> 的文章来作为每个作品的简介。
      </p>
    <% } else { %>
      <div class="space-y-6 md:space-y-8">
        <% projects.sort(function (a, b) { return b.date - a.date; }).forEach(function (project) { %>
          <article class="flex flex-col md:flex-row items-stretch md:items-center gap-4 md:gap-6 p-4 md:p-5 rounded-2xl bg-surface-container-lowest dark:bg-slate-900/70 border border-outline-variant/60 dark:border-slate-800 hover:border-secondary/70 dark:hover:border-orange-500/70 transition-colors">
            <a href="<%- url_for(project.path) %>" class="w-full md:w-40 h-32 md:h-24 rounded-xl overflow-hidden bg-surface-variant dark:bg-slate-800 flex-shrink-0 block">
              <% 
                // --- 路径解析魔法 开始 ---
                let coverUrl = project.cover || project.thumbnail || 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=800&auto=format&fit=crop';
                if (coverUrl && !coverUrl.startsWith('http') && !coverUrl.startsWith('/')) {
                  let parts = coverUrl.split('/');
                  let fileName = parts[parts.length - 1];
                  coverUrl = url_for(project.path + fileName);
                }
                // --- 路径解析魔法 结束 ---
              %>
              <img src="<%- coverUrl %>" alt="<%- project.title %>" class="w-full h-full object-cover transition-transform duration-500 hover:scale-105"/>
            </a>
            <div class="flex-1 flex flex-col justify-between">
              <div>
                <a href="<%- url_for(project.path) %>" class="font-headline text-xl md:text-2xl text-primary dark:text-white tracking-tight hover:text-secondary dark:hover:text-orange-400 transition-colors">
                  <%= project.title %>
                </a>
                <p class="font-body text-sm md:text-base text-on-surface-variant dark:text-gray-300 mt-2 leading-relaxed line-clamp-3">
                  <% if (project.summary) { %>
                    <%- project.summary %>
                  <% } else if (project.excerpt && project.excerpt.length) { %>
                    <%- strip_html(project.excerpt).substr(0, 140) %><% if (strip_html(project.excerpt).length > 140) { %>...<% } %>
                  <% } else { %>
                    <%- strip_html(project.content).substr(0, 140) %><% if (strip_html(project.content).length > 140) { %>...<% } %>
                  <% } %>
                </p>
              </div>
              <div class="mt-3 flex items-center justify-between text-[11px] md:text-xs text-on-surface-variant/80 dark:text-gray-400">
                <span class="font-label uppercase tracking-[0.25em]">
                  <%= date(project.date, 'YYYY.MM.DD') %>
                </span>
                <a href="<%- url_for(project.path) %>" class="inline-flex items-center font-label uppercase tracking-[0.25em] text-secondary dark:text-orange-400 hover:text-orange-600 dark:hover:text-orange-300 transition-colors">
                  查看详情
                  <span class="material-symbols-outlined text-xs ml-1">arrow_right_alt</span>
                </a>
              </div>
            </div>
          </article>
        <% }); %>
      </div>
    <% } %>
  </section>
</main>