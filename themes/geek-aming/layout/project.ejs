<main class="flex-1 w-full flex justify-center px-6 md:px-20 pt-24 md:pt-28 pb-16">
  <div class="w-full max-w-5xl mx-auto">
    <header class="mb-10">
      <div class="flex items-center space-x-3 mb-3">
        <span class="h-px w-8 md:w-12 bg-secondary"></span>
        <span class="font-label text-[10px] md:text-xs uppercase tracking-[0.3em] text-secondary dark:text-orange-400 font-bold">
          作品档案
        </span>
      </div>
      <h1 class="font-headline text-4xl md:text-5xl text-primary dark:text-white leading-tight tracking-tight mb-3">
        <%= page.title %>
      </h1>
      <p class="font-body text-sm md:text-base text-on-surface-variant dark:text-gray-300 max-w-2xl">
        <%= page.subtitle || page.description || '' %>
      </p>
    </header>

    <div class="mb-10 rounded-2xl overflow-hidden bg-surface-variant dark:bg-slate-900 border border-outline-variant/60 dark:border-slate-800">
      <%
        let coverUrl = page.cover || page.thumbnail || 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=800&auto=format&fit=crop';
        if (coverUrl && !coverUrl.startsWith('http') && !coverUrl.startsWith('/')) {
          let parts = coverUrl.split('/');
          let fileName = parts[parts.length - 1];
          coverUrl = url_for(page.path + fileName);
        }
      %>
      <img src="<%- coverUrl %>" alt="<%- page.title %>" class="w-full max-h-[420px] object-cover"/>
    </div>

    <section class="mb-12">
      <h2 class="font-headline text-2xl md:text-3xl text-primary dark:text-white tracking-tight mb-4">
        项目说明
      </h2>
      <div class="prose prose-slate dark:prose-invert max-w-none prose-headings:font-headline prose-headings:tracking-tight prose-p:my-3 md:prose-p:my-4 prose-p:leading-relaxed prose-img:rounded-lg prose-a:text-secondary prose-a:no-underline hover:prose-a:underline prose-code:bg-surface-variant/70 prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded-md prose-code:text-[0.85em] prose-pre:bg-slate-900 prose-pre:text-slate-100 prose-pre:rounded-xl prose-pre:px-4 prose-pre:py-3 prose-pre:text-[0.85em]">
        <%- page.content %>
      </div>
    </section>

    <% var postsArray = site.posts && site.posts.toArray ? site.posts.toArray() : (site.posts || []); %>
    <% var projectKey = page.project || page.slug || page.title; %>
    <% var logs = postsArray.filter(function (p) {
      return p.project === projectKey && p._id !== page._id && p.layout !== 'project';
    }); %>

    <% if (logs.length) { %>
      <section>
        <h2 class="font-headline text-2xl md:text-3xl text-primary dark:text-white tracking-tight mb-4">
          创作记录
        </h2>
        <p class="font-body text-xs md:text-sm text-on-surface-variant dark:text-gray-400 mb-4">
          以下是与该作品相关的阶段性记录、拆解与复盘，按时间线排列。
        </p>
        <div class="relative pl-6 md:pl-10">
          <div class="absolute left-2 md:left-3 top-0 bottom-0 border-l border-outline-variant dark:border-slate-700"></div>
          <div class="space-y-6 md:space-y-8">
            <% logs.sort(function (a, b) { return a.date - b.date; }).forEach(function (post) { %>
              <article class="relative pl-4 md:pl-8">
                <div class="absolute -left-1 md:-left-1.5 w-3 h-3 rounded-full bg-secondary dark:bg-orange-500 ring-4 ring-secondary-fixed/60 dark:ring-orange-500/20"></div>
                <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2 md:gap-4 mb-1">
                  <time class="font-label text-[10px] md:text-xs uppercase tracking-[0.25em] text-on-surface-variant dark:text-gray-400">
                    <%= date(post.date, 'YYYY.MM.DD') %>
                  </time>
                  <a href="<%- url_for(post.path) %>" class="font-headline text-base md:text-lg text-primary dark:text-white tracking-tight hover:text-secondary dark:hover:text-orange-400 transition-colors">
                    <%= post.title %>
                  </a>
                </div>
                <p class="font-body text-xs md:text-sm text-on-surface-variant dark:text-gray-300 leading-relaxed line-clamp-2">
                  <% if (post.excerpt && post.excerpt.length) { %>
                    <%- strip_html(post.excerpt).substr(0, 120) %><% if (strip_html(post.excerpt).length > 120) { %>...<% } %>
                  <% } else { %>
                    <%- strip_html(post.content).substr(0, 120) %><% if (strip_html(post.content).length > 120) { %>...<% } %>
                  <% } %>
                </p>
              </article>
            <% }); %>
          </div>
        </div>
      </section>
    <% } %>
  </div>
</main>

